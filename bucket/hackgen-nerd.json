    "version": "2.10.0",
    "url": "https://github.com/yuru7/HackGen/releases/download/v2.10.0/HackGen_NF_v2.10.0.zip",
    "hash": "sha256:F8ABD483D5EDFAD88A78ED511978F43C83B43C48E364AA29EBE4A68217474428",

    "extract_dir": "HackGen_NF_v2.10.0",

    "installer": {
        "script": [
            "Write-Host \"Installing HackGen Nerd fonts...\"",
            "$fontdir = \"$env:LocalAppData\\Microsoft\\Windows\\Fonts\"",

            "Get-ChildItem $dir -Filter '*.ttf' | ForEach-Object {",
            "   $fontName = $_.Name",
            "   $regName = $fontName.Replace($_.Extension, ' (TrueType)')",
            "   Copy-Item $_.FullName -Destination $fontdir -Force",
            "   New-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name $regName -Value \"$fontdir\\$fontName\" -Force | Out-Null",
            "}"
        ]
    },

    "uninstaller": {
        "script": [
            "Write-Host \"Removing HackGen Nerd fonts...\"",
            "$fontdir = \"$env:LocalAppData\\Microsoft\\Windows\\Fonts\"",

            "Get-ChildItem $dir -Filter '*.ttf' | ForEach-Object {",
            "   $fontName = $_.Name",
            "   $regName = $fontName.Replace($_.Extension, ' (TrueType)')",
            "   Remove-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name $regName -Force -ErrorAction SilentlyContinue",
            "   Remove-Item \"$fontdir\\$fontName\" -Force -ErrorAction SilentlyContinue",
            "}"
        ]
    }
}
